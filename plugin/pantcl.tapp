,{"t":"CodeBlock","c":[["",["tsvg"],[["label","logo"]]],"tsvg proc logo_tsvg {{filename \"\"}} {\n    tsvg set code \"\"\n    tsvg set width 100\n    tsvg set height 60\n    tsvg rect x 0 y 0 width 100 height 100 fill #F64935\n    tsvg text x 20 y 40 style \"font-size:24px;fill:blue;\" tSVG\n    if {$filename ne \"\"} {\n       tsvg write $filename\n    }\n}\ntsvg logo_tsvg logo.svg"]}
