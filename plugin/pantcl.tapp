#(set! paper-alist
  (cons '("my size" . (cons (* 3 in) (* 0.8 in))) paper-alist))
\paper {  #(set-paper-size "my size") }
{
  % middle tie looks funny here:
  <c' d'' b''>8. ~ <c' d'' b''>8
}
