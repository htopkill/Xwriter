	set decode_utf16 {{bytes encoding} {
		set process_utf16_word {char {
			upvar 1 w1 w1  w2 w2

			set t	[expr {$char & 0b1111110000000000}]
			if {$t == 0b1101100000000000} { # high surrogate
				set w1	[expr {$char & 0b0000001111111111}]
			} elseif {$t == 0b1101110000000000} { # low surrogate
				set w2	[expr {$char & 0b0000001111111111}]
			} else {
				return [format %c $char]
			}

			if {[info exists w1] && [info exists w2]} {
				set char	[expr {($w1 << 10) | $w2 | 0x10000}]
				unset -nocomplain w1 w2
				return [format %c $char]
			}

			return
		}}

		if {[string range $encoding 0 1] eq {x }} {
			set encoding [string range $encoding 2 end]
		} elseif {$encoding in [encoding names]} {
			return [encoding convertfrom $encoding $bytes]
		}
		binary scan $bytes [expr {$encoding eq {utf-16le} ? {su*} : {Su*}}] chars
		set res	{}
		foreach char $chars {
			append res [apply $process_utf16_word $char]
		}
		set res
	}}

	set decode_utf32 {{bytes encoding} {
		if {[string range $encoding 0 1] eq {x }} {
			set encoding [string range $encoding 2 end]
		} elseif {$encoding in [encoding names]} {
			puts "$encoding is in \[encoding names\], using native"
			return [encoding convertfrom $encoding $bytes]
		}
		binary scan $bytes [expr {$encoding eq {utf-32le} ? {iu*} : {Iu*}}] chars
		set res	{}
		foreach char $chars {
			append res [format %c $char]
		}
		set res
	}}

	if {$encoding eq {auto}} {
		set bom	[binary encode hex [string range $bytes 0 3]]
		switch -glob -- $bom {
			0000feff { set encoding utf-32be }
			fffe0000 { set encoding utf-32le }
			feff*    { set encoding utf-16be }
			fffe*    { set encoding utf-16le }

			efbbbf -
			default { # No BOM, or UTF-8 BOM
				set encoding utf-8
			}
		}
	}

	switch -- $encoding {
		utf-8 {
			encoding convertfrom utf-8 $bytes
		}

		{x utf-16le} -
		{x utf-16be} -
		utf-16le -
		utf-16be { apply $decode_utf16 $bytes $encoding }

		{x utf-32le} -
		{x utf-32be} -
		utf-32le -
		utf-32be { apply $decode_utf32 $bytes $encoding }

		default {
			error "Unsupported encoding \"$encoding\""
		}
	}
}
