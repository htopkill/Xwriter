\version "2.14.1"

#(set! paper-alist
  (cons '("my size" . (cons (* 3 in) (* 0.8 in))) paper-alist))
\paper {  #(set-paper-size "my size") }
{
  % middle tie looks funny here:
  <c' d'' b''>8. ~ <c' d'' b''>8
}

\paper {
  indent = 0\mm
  line-width = 110\mm
  oddHeaderMarkup = ""
  evenHeaderMarkup = ""
  oddFooterMarkup = ""
  evenFooterMarkup = ""
}
\header { tagline = "" }

