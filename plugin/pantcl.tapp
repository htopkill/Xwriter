␀␀␀␀␀␀␀␀␀␀␀␀␀When iterating over a JSON object, varlist must be a pair of varnames (key value)␀␀␀␀␀␀␀Cannot iterate over JSON type ␀␀Wrong # of arguments.  Must be "␀␀␀␀␀␀␀␀Error removing before tmp file: %s␀␀␀␀␀␀Error removing after tmp file: %s␀␀␀␀␀␀␀Only strings allowed as object keys␀␀␀␀␀Iteration result must be a list with an even number of elements␀Only strings allowed as object keys, got %s␀␀␀␀␀Error substituting value from "%s" into template, not a number: "%s"␀␀␀␀Corrupt internal rep: invalid type ␀␀␀␀␀json new object needs an even number of arguments␀␀␀␀␀␀␀Can't get intrep for container␀␀ modifier is not supported for type ␀␀␀␀Found JSON_UNDEF type jval following path␀␀␀␀␀␀␀Path element %d: "%s" not found␀Expected an integer index or end(-integer)?, got ␀␀␀␀␀␀␀Cannot descend into atomic type "%s" with path element %d: "%s"␀?-extensions extensionslist -details detailsvar? json_val␀␀␀␀␀␀␀	Leaked obj: %p[%d] len %d: "%s"
␀␀␀␀␀␀␀Invalid actions (odd number of elements)␀␀␀␀␀␀␀␀Error substituting value from "%s" into template, not a boolean: "%s"␀␀␀target is shared for REPLACE_ARR␀␀␀␀␀␀␀␀Could not fetch array intrep for target array %s␀␀␀␀␀␀␀␀Could not fetch array intrep for target object %s␀␀␀␀␀␀␀Only strings allowed as object keys, got: %s for key "%s"␀␀␀␀␀␀␀Can't retrieve objType for dict␀Can't retrieve objType for int␀␀Can't retrieve objType for double␀␀␀␀␀␀␀{bytes {encoding auto}} {
	set decode_utf16 {{bytes encoding} {
		set process_utf16_word {char {
			upvar 1 w1 w1  w2 w2

			set t	[expr {$char & 0b1111110000000000}]
			if {$t == 0b1101100000000000} { # high surrogate
				set w1	[expr {$char & 0b0000001111111111}]
			} elseif {$t == 0b1101110000000000} { # low surrogate
				set w2	[expr {$char & 0b0000001111111111}]
			} else {
				return [format %c $char]
			}

			if {[info exists w1] && [info exists w2]} {
				set char	[expr {($w1 << 10) | $w2 | 0x10000}]
				unset -nocomplain w1 w2
				return [format %c $char]
			}

			return
		}}

		if {[string range $encoding 0 1] eq {x }} {
			set encoding [string range $encoding 2 end]
		} elseif {$encoding in [encoding names]} {
			return [encoding convertfrom $encoding $bytes]
		}
		binary scan $bytes [expr {$encoding eq {utf-16le} ? {su*} : {Su*}}] chars
		set res	{}
		foreach char $chars {
			append res [apply $process_utf16_word $char]
		}
		set res
	}}

	set decode_utf32 {{bytes encoding} {
		if {[string range $encoding 0 1] eq {x }} {
			set encoding [string range $encoding 2 end]
		} elseif {$encoding in [encoding names]} {
			puts "$encoding is in \[encoding names\], using native"
			return [encoding convertfrom $encoding $bytes]
		}
		binary scan $bytes [expr {$encoding eq {utf-32le} ? {iu*} : {Iu*}}] chars
		set res	{}
		foreach char $chars {
			append res [format %c $char]
		}
		set res
	}}

	if {$encoding eq {auto}} {
		set bom	[binary encode hex [string range $bytes 0 3]]
		switch -glob -- $bom {
			0000feff { set encoding utf-32be }
			fffe0000 { set encoding utf-32le }
			feff*    { set encoding utf-16be }
			fffe*    { set encoding utf-16le }

			efbbbf -
			default { # No BOM, or UTF-8 BOM
				set encoding utf-8
			}
		}
	}

	switch -- $encoding {
		utf-8 {
			encoding convertfrom utf-8 $bytes
		}

		{x utf-16le} -
		{x utf-16be} -
		utf-16le -
		utf-16be { apply $decode_utf16 $bytes $encoding }

		{x utf-32le} -
		{x utf-32be} -
		utf-32le -
		utf-32be { apply $decode_utf32 $bytes $encoding }

		default {
			error "Unsupported encoding \"$encoding\""
		}
